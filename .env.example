PYTHONDONTWRITEBYTECODE=1

# ── Kronos model ──────────────────────────────────────────────────────────────
# These stay in .env because they affect which model binary is loaded at startup.
KRONOS_MODEL_SIZE=small          # mini | small | base
KRONOS_DEVICE=cuda               # cuda | cpu | mps
KRONOS_MAX_CONTEXT=512
KRONOS_FORECAST_HORIZON=24       # bars ahead to forecast
KRONOS_MC_SAMPLES=50             # Monte Carlo samples for uncertainty bands

# ── Broker credentials ────────────────────────────────────────────────────────
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true                # true = paper trading endpoint
DATABENTO_API_KEY=your_key_here  # optional — leave blank to disable Databento feed

# ── OANDA (forex / CFD) ───────────────────────────────────────────────────────
# Create a free practice account at https://www.oanda.com/forex-trading/
# API token: My Account → Manage API Access → Generate
# Account ID: appears in the URL after logging in, or in My Account → Overview
OANDA_API_TOKEN=your_token_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_PRACTICE=true              # true = fxTrade Practice, false = fxTrade Live
# Usage: python scripts/run_system.py --broker oanda --symbols EURUSD,AUDJPY

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite+aiosqlite:///./kronos_trade.db

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8765
API_SECRET=change_me_in_production

# ── NinjaTrader bridge (optional) ─────────────────────────────────────────────
NT8_WEBHOOK_HOST=localhost
NT8_WEBHOOK_PORT=8080
NT8_ACCOUNT_ID=Sim101

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/kronos_trade.log

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=                        # optional — avoids rate limits on model downloads
HF_HOME=
HF_HUB_CACHE=
TORCH_HOME=
TRANSFORMERS_CACHE=

# ── Runtime config ────────────────────────────────────────────────────────────
# Instruments, timeframe, trading mode, risk limits, and strategy params are
# stored in kats_config.json (auto-created on first run with sensible defaults).
# Edit them live via the TUI instruments panel and mode/timeframe keys,
# or directly in kats_config.json — changes take effect on next restart.
# Do NOT add those params here; .env values cannot override kats_config.json.
